<UserControl x:Class="TestCaseEditorApp.MVVM.Domains.Notification.Views.NotificationWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:conv="clr-namespace:TestCaseEditorApp.Converters"
             mc:Ignorable="d"
             d:DesignHeight="28" d:DesignWidth="1200">

    <UserControl.Resources>
        <conv:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsedConverter" />
        <conv:BoolToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </UserControl.Resources>

    <!-- Notification workspace layout - Domain-agnostic notification display -->
    <Border Background="#222222" 
            Padding="10,4"
            Height="28"
            Visibility="{Binding IsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- AnythingLLM Status -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,16,0">
                <Ellipse Width="8" Height="8" 
                        Fill="{Binding AnythingLlmStatusColor}" 
                        VerticalAlignment="Center" 
                        Margin="0,0,6,0"/>
                <TextBlock Text="{Binding AnythingLlmStatusText}" 
                          FontSize="11" 
                          Foreground="#BBBBBB" 
                          VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Ollama Status -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,0">
                <Ellipse Width="8" Height="8" 
                        Fill="{Binding OllamaStatusColor}" 
                        VerticalAlignment="Center" 
                        Margin="0,0,6,0"/>
                <TextBlock Text="{Binding OllamaStatusText}" 
                          FontSize="11" 
                          Foreground="#BBBBBB" 
                          VerticalAlignment="Center"
                          Margin="0,0,8,0"/>
                <CheckBox Content="Keep Loaded" 
                         IsChecked="{Binding KeepOllamaLoaded}" 
                         Command="{Binding ToggleKeepOllamaLoadedCommand}"
                         Foreground="#BBBBBB" 
                         FontSize="10"
                         VerticalAlignment="Center"
                         Visibility="{Binding OllamaLoadedModel, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                    <CheckBox.ToolTip>
                        <ToolTip>
                            <TextBlock>
                                <Run Text="Keep model loaded in memory to avoid ~45-second load time."/>
                                <LineBreak/>
                                <Run Text="Checked: Keep for 30 minutes"/>
                                <LineBreak/>
                                <Run Text="Unchecked: Unload after 5 minutes of inactivity"/>
                            </TextBlock>
                        </ToolTip>
                    </CheckBox.ToolTip>
                </CheckBox>
            </StackPanel>
            
            <!-- Current Requirement Verification Method -->
            <StackPanel Grid.Column="3" Orientation="Horizontal" 
                       HorizontalAlignment="Right"
                       Margin="0,0,8,0"
                       Visibility="{Binding CurrentRequirementVerificationMethod, Converter={StaticResource EmptyStringToCollapsedConverter}}">
                <TextBlock Text="Method:" 
                          Width="50"
                          FontSize="11" 
                          Foreground="#999999" 
                          VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentRequirementVerificationMethod}" 
                          FontSize="11" 
                          Foreground="#DDDDDD" 
                          VerticalAlignment="Center"
                          FontWeight="SemiBold"/>
                <TextBlock Text=" | " 
                          FontSize="11" 
                          Foreground="#666666" 
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"/>
            </StackPanel>
            
            <!-- Requirements Progress -->
            <StackPanel Grid.Column="4" Orientation="Horizontal">
                <TextBlock Text="{Binding RequirementsProgressText}" 
                          FontSize="11" 
                          Foreground="#BBBBBB" 
                          VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
